# ─── TechBuddy environment ───────────────────────────────────────────
# Copy to .env.local and fill values you need.

# Database — SQLite for local dev. Swap to postgresql://... for prod.
DATABASE_URL="file:./dev.db"

# NextAuth v5
NEXTAUTH_SECRET=change-me-to-a-32-char-random-string
# Set this to match the origin you actually run (e.g. http://localhost:3015 for
# the Playwright dev server, http://localhost:3000 for `next dev` default, or
# your prod origin). Mismatches cause sign-in to redirect to a dead port.
NEXTAUTH_URL=http://localhost:3015

# Anthropic (scam checker + practice mode + ai explainer)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Z.ai (existing integration — kept for backwards compatibility)
Z_AI_API_KEY=
Z_AI_BASE_URL=https://api.z.ai/api/coding/paas/v4/
# Z_AI_MODEL=glm-4.6

# Optional: Upstash Redis for distributed rate limiting
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: Plausible analytics
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your.domain.com

# Optional: client-side telemetry
# NEXT_PUBLIC_ENABLE_CLIENT_TELEMETRY=false
# NEXT_PUBLIC_ENABLE_WEB_VITALS=false
