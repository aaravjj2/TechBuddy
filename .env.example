# Z.ai (OpenAI-compatible). Create a key at https://chat.z.ai/ or the Z.ai developer console.
# Either name works:
Z_AI_API_KEY=
# ZAI_API_KEY=

# Optional: default https://api.z.ai/api/paas/v4/
# GLM Coding Plan keys often need:
# Z_AI_BASE_URL=https://api.z.ai/api/coding/paas/v4/

# Optional model (platform-dependent), e.g. glm-4.6, glm-4-air, glm-4-plus
# Z_AI_MODEL=glm-4.6

# Optional: rate limit API routes (Node). Create a Redis database at https://upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: Plausible analytics (your site domain as configured in Plausible)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=your.domain.com
